{
  "name": "@cboxdk/id-vue",
  "version": "0.1.0",
  "description": "Embeddable Vue 3 widgets for Cbox ID — a drop-in user button, sign-in / sign-out buttons, profile card and organization badge, wired to your Cbox ID hosted flows. Themeable, accessible, zero-config.",
  "type": "module",
  "license": "MIT",
  "author": "Sylvester Damgaard <sn@cbox.dk>",
  "homepage": "https://github.com/cboxdk/id-vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cboxdk/id-vue.git"
  },
  "bugs": {
    "url": "https://github.com/cboxdk/id-vue/issues"
  },
  "keywords": [
    "cbox-id",
    "vue",
    "authentication",
    "widgets",
    "user-button",
    "oidc",
    "nuxt"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0",
    "vue": "^3.5.0"
  }
}
